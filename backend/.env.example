# Salesforce
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# AI API keys (tries Claude → Grok → OpenAI)
ANTHROPIC_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=

# AI models
CLAUDE_MODEL=claude-sonnet-4-20250514
GROK_MODEL=grok-3-mini-fast
OPENAI_MODEL=gpt-4o

# Embedding model for RAG (OpenAI)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Schema refresh schedule
AUTO_SYNC_TIME=02:00

# IMPORTANT: Generate a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
